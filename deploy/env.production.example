# Copy to /opt/prompt-clash/.env.production ON THE VM and fill in real values.
# Never commit the filled-in file — .gitignore already excludes .env.production.

NODE_ENV=production
PORT=3000

# Public URL of the app. Used for SEO/OG metadata (baked at build time via the
# NEXT_PUBLIC_APP_URL build arg) and for the Socket.io CORS allow-list.
NEXT_PUBLIC_APP_URL=https://clash.example.com
ALLOWED_ORIGIN=https://clash.example.com

# --- Image provider: cloudflare | pollinations | gemini ---
IMAGE_PROVIDER=cloudflare
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# --- Scoring + prompt expansion (Gemini). Extra keys rotate for quota. ---
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=

# --- Storage: local (container volume at /app/public/uploads) | gcs ---
STORAGE_PROVIDER=local
# GCS_BUCKET=
# GCS_SA_KEY_JSON={"type":"service_account",...}

# --- MongoDB (REQUIRED in production by validateEnv; app degrades if unreachable).
# The docker-compose.yml ships a `mongo` service, so use the compose hostname: ---
MONGODB_URI=mongodb://mongo:27017/promptclash

# --- DEMO_MODE=1 bypasses real image gen + AI scoring with placeholders.
# Leave unset (or 0) for live games; then real provider keys above are required. ---
DEMO_MODE=

# --- Admin panel ---
ADMIN_PASSWORD=
ADMIN_COOKIE_SECRET=

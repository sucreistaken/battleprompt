# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
PORT=3000
NODE_ENV=development

# --- MongoDB (Atlas) ---
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/promptclash?retryWrites=true&w=majority

# --- Image provider ---
# pollinations = ücretsiz, API key GEREKMEZ (default) | gemini = key gerekir
IMAGE_PROVIDER=pollinations

# --- Pollinations (ücretsiz / key'siz) ---
POLLINATIONS_IMAGE_MODEL=flux
POLLINATIONS_IMAGE_WIDTH=1024
POLLINATIONS_IMAGE_HEIGHT=1024
# İsteğe bağlı: enter.pollinations.ai'den alınan key ile rate limit artar
# POLLINATIONS_API_KEY=

# --- Gemini (IMAGE_PROVIDER=gemini ise) ---
GEMINI_API_KEY=your-gemini-key-here
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
GEMINI_TEXT_MODEL=gemini-2.5-flash-lite

# --- Google Cloud Storage ---
GCS_BUCKET=promptclash-images
# Either set the path to a service account JSON file:
GOOGLE_APPLICATION_CREDENTIALS=./gcs-key.json
# Or paste the JSON inline (used in Cloud Run via Secret Manager):
# GCS_SA_KEY_JSON={"type":"service_account",...}

# --- Admin auth ---
ADMIN_PASSWORD=change-me
ADMIN_COOKIE_SECRET=replace-with-long-random-hex
